OBJS=${SRC:.f90=.o}

FC = gfortran
FC_FLAGS=-O3 -Wall -Wextra

$(EXE): $(OBJS)
	$(FC) -o $@ $? $(FC_LD) $(LIBS) $(LAPACK_LIBS)

%.o: %.f90
	$(FC) -c $(FC_FLAGS)  -o $@ $<

clean:
	-@rm $(EXE)
	-@rm *.o *.mod
